  <div class="wrap">
    <div class="sec-head">
      <span class="sec-no">No. iv</span>
      <span class="sec-label">Contact</span>
      <svg class="sec-flourish" viewBox="0 0 300 16" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" filter="url(#inkbleed)">
        <path d="M2 8 C 58 12 118 5 182 10 C 240 13.6 272 7 298 9 L 298 10.6 C 272 10 240 16 182 13 C 118 8.6 58 15 2 10 Z" fill="#74202c" opacity="0.8"/>
      </svg>
    </div>

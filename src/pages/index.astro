      <div>
        <h2>Have a project that needs <span class="script">to ship?</span></h2>
        <div class="contact-lines">
          <span class="label">Email</span>
          <a class="big" href="mailto:contact@gluax.ink">contact@gluax.ink</a>
          <svg class="u" viewBox="0 0 320 14" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" filter="url(#inkbleed)">
            <path d="M2 8 C 65 4 150 11 225 7 C 275 4.6 300 9 318 6.4 L 318 8.6 C 300 12 275 7.6 225 10 C 150 14 65 9 2 11 Z" fill="#74202c" opacity="0.85"/>
          </svg>
          <span class="label">GitHub</span>
          <a class="big" href="https://github.com/gluax">github.com/gluax</a>
          <svg class="u" viewBox="0 0 320 14" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" filter="url(#inkbleed)">
            <path d="M2 6.6 C 75 10.6 160 4 235 8.6 C 282 11.4 302 7 318 9 L 318 11 C 302 10 282 14.4 235 11.6 C 160 7 75 13.6 2 9 Z" fill="#74202c" opacity="0.85"/>
          </svg>
        </div>
      </div>
      <div class="seal-col">
        <svg viewBox="0 0 200 200" width="190" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <!-- wax blob -->
          <path filter="url(#inkbleed)" d="M100 14c12-3 22 6 34 6 12 1 24-6 34 1 10 6 8 20 14 30 6 11 19 18 18 30-1 12-15 17-20 28-5 10-2 24-11 31-9 8-22 2-34 5-11 3-21 13-33 12-12-1-19-13-30-18-10-5-24-3-31-12-7-9 0-22-3-33-3-12-14-21-11-33 3-11 17-13 25-22 8-8 11-21 22-25 9-3 17 3 26 0z" fill="#74202c"/>

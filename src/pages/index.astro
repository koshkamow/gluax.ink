          <circle cx="100" cy="100" r="54" fill="none" stroke="#f2ddb4" stroke-width="1.3" stroke-dasharray="1 4" stroke-linecap="round" opacity="0.6"/>
          <!-- owl -->
          <g transform="translate(100,97) scale(0.84) translate(-100,-100)" stroke="#f2ddb4" fill="none" stroke-width="3.6" stroke-linecap="round" stroke-linejoin="round">
            <!-- ear tufts -->
            <path d="M76 70 L66 50 L92 61"/>
            <path d="M124 70 L134 50 L108 61"/>
            <!-- head -->
            <path d="M72 88 C 72 71 84 60 100 60 C 116 60 128 71 128 88 C 128 100 120 108 100 108 C 80 108 72 100 72 88 Z"/>
            <!-- eyes -->
            <circle cx="86" cy="85" r="11.5"/>
            <circle cx="114" cy="85" r="11.5"/>
            <!-- body -->
            <path d="M78 104 C 70 118 70 134 80 144 C 89 152 111 152 120 144 C 130 134 130 118 122 104" stroke-width="3.4"/>
